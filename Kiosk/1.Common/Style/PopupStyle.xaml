<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converter="clr-namespace:Kiosk.Converters">
    <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <converter:MinusConverter x:Key="MinusConverter"/>
    <Style x:Key="BasePopupBorder" TargetType="Border">
        <Setter Property="Width" Value="{Binding Content.Width, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
        <Setter Property="Height" Value="{Binding Content.Height, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BasePopupStyle" TargetType="ContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid Background="#80000000">
                        <Border Style="{StaticResource BasePopupBorder}">
                            <Grid>
                                <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                                        BorderThickness="1" Width="{Binding Width, RelativeSource={RelativeSource AncestorType=Border}}" 
                                        Height="{Binding Height, RelativeSource={RelativeSource AncestorType=Border},
                                                    Converter={StaticResource MinusConverter}, ConverterParameter=120}">
                                    <ContentPresenter/>
                                </Border>
                                <TextBlock Text="{Binding Content.Title, RelativeSource={RelativeSource TemplatedParent}}"
                                           VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" FontWeight="Bold"/>

                                <UniformGrid Rows="1">
                                    <Button Content="닫기" Style="{StaticResource GrayButtonStyle}"
                                    VerticalAlignment="Bottom"
                                    Margin="0" Height="60"
                                    Command="{Binding Content.CancelCommand,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="{Binding Content.ShowCancel,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Button Content="이전" Style="{StaticResource SlateGrayButtonStyle}"
                                    VerticalAlignment="Bottom"
                                    Margin="0" Height="60"
                                    Command="{Binding Content.PrevCommand,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="{Binding Content.ShowPrev,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Button Content="다음" Style="{StaticResource RedButtonStyle}"
                                    VerticalAlignment="Bottom"
                                    Margin="0" Height="60"
                                    Command="{Binding Content.NextCommand,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="{Binding Content.ShowNext,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Button Content="확인" Style="{StaticResource RedButtonStyle}"
                                    VerticalAlignment="Bottom"
                                    Margin="0" Height="60"
                                    Command="{Binding Content.OKCommand,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="{Binding Content.ShowOK,
                                              RelativeSource={RelativeSource TemplatedParent},
                                              Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>