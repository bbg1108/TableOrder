<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Color -->
    <SolidColorBrush x:Key="VoicePrimaryBrush" Color="#2B6CB0"/>
    <SolidColorBrush x:Key="VoiceBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="VoiceBorderBrush" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="VoiceTextPrimaryBrush" Color="#222222"/>

    <!-- Text -->
    <Style x:Key="VoiceTtsTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource VoiceTextPrimaryBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <Style x:Key="VoiceSttTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource VoicePrimaryBrush}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <!-- Border -->
    <Style x:Key="VoicePanelContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource VoiceBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource VoiceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- Chat Styles -->
    <!-- 왼쪽 (TTS) 말풍선 -->
    <Style x:Key="VoiceTtsBubbleStyle" TargetType="Border">
        <Setter Property="Background" Value="#F1F1F1"/>
        <Setter Property="CornerRadius" Value="0,20,20,20"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="MaxWidth" Value="900"/>
    </Style>

    <!-- 오른쪽 (STT) 말풍선 -->
    <Style x:Key="VoiceSttBubbleStyle" TargetType="Border">
        <Setter Property="Background" Value="#E6F0FA"/>
        <Setter Property="CornerRadius" Value="20,0,20,20"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="MaxWidth" Value="900"/>

        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="Transparent"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding STTStatus}" Value="Fail">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard FillBehavior="Stop">
                            <ColorAnimation
                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                To="Red"
                                Duration="0:0:0.2"
                                AutoReverse="True"
                                RepeatBehavior="3x"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
            </DataTrigger>

            <DataTrigger Binding="{Binding STTStatus}" Value="Success">
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard FillBehavior="Stop">
                            <ColorAnimation
                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                To="LimeGreen"
                                Duration="0:0:0.2"
                                AutoReverse="True"
                                RepeatBehavior="3x"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>