<UserControl x:Class="Kiosk.Views.Popups.CheckOrderPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:Kiosk.Views.Popups"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="Loaded">
                <i:InvokeCommandAction Command="{Binding InitCommand}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.11*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0.1*"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <TextBlock Text="주문내역을 확인해주세요"
               Grid.Row="0"
               Style="{StaticResource TitleFont}"/>

            <!-- 주문 목록 -->
            <ListView Grid.Row="1" ItemsSource="{Binding Cart}"
                      BorderThickness="0" Background="White" Margin="16,8"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.Resources>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource BaseScrollViewer}"/>
                </ListView.Resources>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F9F9F9" Padding="16,12" Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="0.15*"/>
                                    <ColumnDefinition Width="0.15*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 메뉴명 -->
                                <TextBlock Grid.Column="0" Text="{Binding Item.Name}" Style="{StaticResource BoldFont}" HorizontalAlignment="Stretch"/>

                                <!-- 수량 -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock Text="수량 " Style="{StaticResource BaseFont}"/>
                                    <TextBlock Text="{Binding Item.Count}" Style="{StaticResource BoldFont}"/>
                                </StackPanel>

                                <!-- 가격 -->
                                <TextBlock Grid.Column="2"
                                   Text="{Binding Item.Price, StringFormat={}{0:N0}원}" Style="{StaticResource BoldFont}"
                                   Foreground="{StaticResource ThemeRedBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 총 주문 금액 -->
            <Grid Grid.Row="2" Margin="10,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="총 주문 금액 " Grid.Column="0" Style="{StaticResource LargeFont}"/>
                <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N0}원}" Grid.Column="1" Style="{StaticResource LargeFont}"
                           Foreground="{StaticResource ThemeRedBrush}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
