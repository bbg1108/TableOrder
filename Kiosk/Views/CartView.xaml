<UserControl x:Class="Kiosk.Views.CartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Kiosk.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="450">
    <Border Style="{StaticResource BaseBorder}">
        <Grid DataContext="{Binding CartViewModel}" Background="#F3F3F3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0.1*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.12*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="0.1*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.48*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="장바구니" Grid.Column="0" Style="{StaticResource LargeFont}"/>
                    <Button Content="전체삭제" Grid.Column="1" Command="{Binding ClearCommand}" Style="{StaticResource GrayButtonStyle}"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource OverlayVerticalScrollViewer}">
                    <ItemsControl ItemsSource="{Binding CartItems}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0 10"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="50">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding Item.Name}" Grid.Row="0" Style="{StaticResource BoldFont}"
                                               HorizontalAlignment="Left" Margin="10 0"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10 0">
                                            <Button Content="-" Command="{Binding DelItemCommand}" Style="{StaticResource GrayButtonStyle}"
                                                    Width="{Binding RelativeSource={RelativeSource Self}, Path=ActualHeight}"/>
                                            <TextBlock Text="{Binding Count}" Style="{StaticResource BaseFont}" Margin="10 0"/>
                                            <Button Content="+" Command="{Binding AddItemCommand}" Style="{StaticResource RedButtonStyle}"
                                                    Width="{Binding RelativeSource={RelativeSource Self}, Path=ActualHeight}"/>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0}원}" Grid.Column="1" Style="{StaticResource BaseFont}"
                                                   HorizontalAlignment="Right" Margin="10 0"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                
                <TextBlock Grid.Row="2" Text="{Binding TotalPrice, StringFormat={}{0:N0}원}" Style="{StaticResource LargeFont}"
                           Foreground="{StaticResource ThemeRedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4 0"/>
            </Grid>

            <Button Grid.Row="1" Content="결제하기" Command="{Binding PayCommand}"
                    Style="{StaticResource RedButtonStyle}"/>
            </Grid>
    </Border>
</UserControl>
