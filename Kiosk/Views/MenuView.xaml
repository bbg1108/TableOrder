<UserControl x:Class="Kiosk.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Kiosk.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid DataContext="{Binding MenuViewModel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <ItemsControl ItemsSource="{Binding DisplayProducts}" Grid.Row="0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="2" Columns="4"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding SelectItemCommand}" CommandParameter="{Binding Product}"
                            Style="{StaticResource ImageButtonStyle}" MaxHeight="200" Margin="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="2*"/>
                            </Grid.RowDefinitions>

                            <Image Grid.Row="0" Source="{Binding Product.ImagePath, TargetNullValue='../../1.Common/Resources/Images/No_Image.png'}"
                                   Stretch="Uniform"/>

                            <TextBlock Grid.Row="1" Text="{Binding Product.Name}" Style="{StaticResource BoldFont}"/>

                            <TextBlock Grid.Row="2" Text="{Binding Product.Price, StringFormat={}{0:N0}원}"
                                           Style="{StaticResource BoldFont}" Foreground="{StaticResource ThemeRedBrush}"/>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Content="이전" Command="{Binding PrevButtonCommand}" Grid.Column="0" Style="{StaticResource GrayButtonStyle}" Margin="2 0 2 0"/>
            <Button Content="다음" Command="{Binding NextButtonCommand}" Grid.Column="1" Style="{StaticResource GrayButtonStyle}" Margin="2 0 2 0"/>
        </Grid>
    </Grid>
</UserControl>
